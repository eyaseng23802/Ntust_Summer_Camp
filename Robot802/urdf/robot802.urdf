<?xml version="1.0"?>
<robot name="assignment_manipulator">

  <!-- Link 1: White Base Cylinder -->
  <link name="base_link">
    <visual>
      <geometry><cylinder length="0.5" radius="0.1"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.5" radius="0.1"/></geometry>
    </collision>
  </link>

  <!-- Joint 0: Base Rotation Ring (arm_0_joint) -->
  <joint name="arm_0_joint" type="revolute">
    <parent link="base_link"/><child link="link_arm0"/>
    <origin xyz="0 0 0.25"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <!-- Link: The Red Rotating Ring around the base -->
  <link name="link_arm0">
    <visual>
      <geometry><cylinder length="0.15" radius="0.15"/></geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.15" radius="0.15"/></geometry>
    </collision>
  </link>

  <!-- Joint 1: Shoulder Pitch (arm_1_joint) -->
  <joint name="arm_1_joint" type="revolute">
    <parent link="link_arm0"/><child link="link_arm1"/>
    <origin xyz="0 0 0.075"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- Link: First Long Red Arm Segment -->
  <link name="link_arm1">
    <visual>
      <origin xyz="0 0 0.25"/>
      <geometry><cylinder length="0.5" radius="0.08"/></geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.25"/>
      <geometry><cylinder length="0.5" radius="0.08"/></geometry>
    </collision>
  </link>

  <!-- Joint 2: Elbow Pitch (arm_2_joint) -->
  <joint name="arm_2_joint" type="revolute">
    <parent link="link_arm1"/><child link="link_arm2"/>
    <origin xyz="0 0 0.5"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- Link: Second Long White Arm Segment -->
  <link name="link_arm2">
    <visual>
      <origin xyz="0 0 0.25"/>
      <geometry><cylinder length="0.5" radius="0.06"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.25"/>
      <geometry><cylinder length="0.5" radius="0.06"/></geometry>
    </collision>
  </link>

  <!-- Fixed Joint to Gripper Plate -->
  <joint name="gripper_base_joint" type="fixed">
    <parent link="link_arm2"/><child link="gripper_base"/>
    <origin xyz="0 0 0.5"/>
  </joint>

  <!-- Link: Red Gripper Base Plate -->
  <link name="gripper_base">
    <visual>
      <origin xyz="0 0 0.01"/>
      <geometry><box size="0.16 0.04 0.02"/></geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.01"/>
      <geometry><box size="0.16 0.04 0.02"/></geometry>
    </collision>
  </link>

  <!-- Gripper Jaw 1 (gripper_1_joint) -->
  <joint name="gripper_1_joint" type="prismatic">
    <parent link="gripper_base"/><child link="left_jaw"/>
    <origin xyz="-0.06 0 0.02"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.05" effort="5" velocity="0.5"/>
  </joint>

  <link name="left_jaw">
    <visual>
      <origin xyz="0 0 0.04"/>
      <geometry><box size="0.02 0.03 0.08"/></geometry>
      <material name="yellow"><color rgba="1 1 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.04"/>
      <geometry><box size="0.02 0.03 0.08"/></geometry>
    </collision>
  </link>

  <!-- Gripper Jaw 2 (gripper_2_joint) -->
  <joint name="gripper_2_joint" type="prismatic">
    <parent link="gripper_base"/><child link="right_jaw"/>
    <origin xyz="0.06 0 0.02"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0.0" upper="0.05" effort="5" velocity="0.5"/>
  </joint>

  <link name="right_jaw">
    <visual>
      <origin xyz="0 0 0.04"/>
      <geometry><box size="0.02 0.03 0.08"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04"/>
      <geometry><box size="0.02 0.03 0.08"/></geometry>
    </collision>
  </link>

</robot>
